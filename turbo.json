{
	"$schema": "https://turborepo.org/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"]
		},
		"export": {
			"dependsOn": ["^build"]
		},
		"check-format": {},
		"check-types": {},
		"test": {
			"cache": false
		},
		"format": {},
		"lint": {},
		"lint:fix": {
			"cache": false
		},
		"lint:fix:unsafe": {
			"cache": false
		},
		"start": {
			"dependsOn": ["build"]
		},
		"dev": {
			"cache": false,
			"env": ["DB_PORT"]
		}
	}
}
