    "react-icons": "5.6.0",
    "rehype-raw": "7.0.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "types": "*",
    "use-query-params": "2.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
