    "@mui/x-license": "8.26.0",
    "@mui/x-tree-view": "8.27.2",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-query-devtools": "5.99.0",
    "@visx/responsive": "3.12.0",
    "lodash": "4.18.1",
    "next": "16.2.3",
