    "@visx/vendor": "3.12.0",
    "lodash": "4.18.1",
    "next": "16.2.3",
    "next-query-params": "5.1.0",
    "qmongjs": "*",
    "react": "19.2.4",
    "react-icons": "5.6.0",
    "rehype-raw": "7.0.0",
    "rehype-slug": "6.0.0",
