{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"types": ["cypress", "@vitest/browser/matchers"],
		"allowJs": true,
		"jsx": "react-jsx",
		"incremental": true,
		"strict": false,
		"strictNullChecks": false,
		"plugins": [{ "name": "next" }]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"vitest.config.ts",
		".next/types/**/*.ts",
		"src/components/HospitalProfile/SelectedIndicatorTable/indicators.ts"
	],
	"exclude": ["./cypress.config.ts", "node_modules", "**/*.test.tsx"]
}
