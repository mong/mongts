		"husky": "^9.1.7",
		"knip": "6.11.0",
		"lint-staged": "16.4.0",
		"turbo": "2.9.6",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"commitlint": "^20.5.2"
